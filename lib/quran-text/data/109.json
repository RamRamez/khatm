{"1":{"a":"قُلْ يَـٰٓأَيُّهَا ٱلْكَـٰفِرُونَ","t":"بگو: «اى كافران،"},"2":{"a":"لَآ أَعْبُدُ مَا تَعْبُدُونَ","t":"آنچه مى‌پرستيد، نمى‌پرستم"},"3":{"a":"وَلَآ أَنتُمْ عَـٰبِدُونَ مَآ أَعْبُدُ","t":"و آنچه مى‌پرستم، شما نمى‌پرستيد"},"4":{"a":"وَلَآ أَنَا۠ عَابِدٌ مَّا عَبَدتُّمْ","t":"و نه آنچه پرستيديد من مى‌پرستم"},"5":{"a":"وَلَآ أَنتُمْ عَـٰبِدُونَ مَآ أَعْبُدُ","t":"و نه آنچه مى‌پرستم شما مى‌پرستيد"},"6":{"a":"لَكُمْ دِينُكُمْ وَلِىَ دِينِ","t":"دين شما براى خودتان، و دين من براى خودم.»"}}