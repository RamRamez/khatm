{"1":{"a":"وَيْلٌ لِّكُلِّ هُمَزَةٍ لُّمَزَةٍ","t":"واى بر هر بدگوى عيبجويى،"},"2":{"a":"ٱلَّذِى جَمَعَ مَالًا وَعَدَّدَهُۥ","t":"كه مالى گرد آورد و برشمردش"},"3":{"a":"يَحْسَبُ أَنَّ مَالَهُۥٓ أَخْلَدَهُۥ","t":"پندارد كه مالش او را جاويد كرده،"},"4":{"a":"كَلَّا ۖ لَيُنۢبَذَنَّ فِى ٱلْحُطَمَةِ","t":"ولى نه! قطعاً در آتش خردكننده فرو افكنده خواهد شد"},"5":{"a":"وَمَآ أَدْرَىٰكَ مَا ٱلْحُطَمَةُ","t":"و تو چه دانى كه آن آتش خردكننده چيست؟"},"6":{"a":"نَارُ ٱللَّهِ ٱلْمُوقَدَةُ","t":"آتش افروخته خدا[يى‌] است"},"7":{"a":"ٱلَّتِى تَطَّلِعُ عَلَى ٱلْأَفْـِٔدَةِ","t":"[آتشى‌] كه به دلها مى‌رسد"},"8":{"a":"إِنَّهَا عَلَيْهِم مُّؤْصَدَةٌ","t":"آنان را در ميان فرامى‌گيرد"},"9":{"a":"فِى عَمَدٍ مُّمَدَّدَةٍۭ","t":"[آتشى كه‌] در ستونهايى دراز است"}}