{"1":{"a":"قُلْ أَعُوذُ بِرَبِّ ٱلنَّاسِ","t":"بگو: «پناه مى‌برم به پروردگار مردم،"},"2":{"a":"مَلِكِ ٱلنَّاسِ","t":"پادشاه مردم،"},"3":{"a":"إِلَـٰهِ ٱلنَّاسِ","t":"معبود مردم،"},"4":{"a":"مِن شَرِّ ٱلْوَسْوَاسِ ٱلْخَنَّاسِ","t":"از شرّ وسوسه‌گر نهانى؛"},"5":{"a":"ٱلَّذِى يُوَسْوِسُ فِى صُدُورِ ٱلنَّاسِ","t":"آن كس كه در سينه‌هاى مردم وسوسه مى‌كند،"},"6":{"a":"مِنَ ٱلْجِنَّةِ وَٱلنَّاسِ","t":"چه از جنّ و [چه از] انس.»"}}